services:
{% for svc_name, svc in (app.runtime.services | default({})).items() %}
  {{ svc_name }}:
    image: "{{ app.image }}"
    container_name: "app-{{ deploy_env }}-{{ svc_name }}"
    restart: unless-stopped

{% if svc.env_file is defined %}
    env_file:
      - "{{ svc.env_file }}"
{% endif %}

{% if svc.environment is defined and svc.environment | length > 0 %}
    environment:
{% for k, v in svc.environment.items() %}
      {{ k }}: {{ v | to_json }}
{% endfor %}
{% endif %}

{% if svc.command is defined %}
    command: {{ svc.command | to_json }}
{% endif %}

{% if svc.expose is defined and svc.expose | length > 0 %}
    expose:
{% for e in svc.expose %}
      - "{{ e }}"
{% endfor %}
{% endif %}

{% if svc.depends_on is defined and svc.depends_on | length > 0 %}
    depends_on:
{% for dep in svc.depends_on %}
      - "{{ dep }}"
{% endfor %}
{% endif %}

{% if svc.healthcheck is defined %}
    healthcheck:
{% for k, v in svc.healthcheck.items() %}
{% if v is sequence and v is not string %}
      {{ k }}: {{ v | to_json }}
{% else %}
      {{ k }}: {{ v | to_json }}
{% endif %}
{% endfor %}
{% endif %}

{% if svc.volumes is defined and svc.volumes | length > 0 %}
    volumes:
{% for v in svc.volumes %}
      - "{{ v }}"
{% endfor %}
{% endif %}

    networks:
      - cluster_shared
{% if svc_name == app.public_service %}
      - proxy_global
{% endif %}

{% endfor %}

networks:
  proxy_global:
    external: true
  cluster_shared:
    external: true
    name: "cluster_{{ deploy_env }}_shared"

{% if app.volumes_def is defined and app.volumes_def | length > 0 %}
volumes:
{% for v in app.volumes_def %}
  {{ v }}:
    external: true
{% endfor %}
{% endif %}
