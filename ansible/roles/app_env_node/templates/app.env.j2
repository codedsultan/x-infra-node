# Ansible managed — DO NOT EDIT ON SERVER (changes will be overwritten)
# app=app env={{ deploy_env }}

{% for k in env_merged.keys() | sort %}
{% set v = env_merged[k] | string %}
{% if v == '' %}
{{ k }}=
{% elif '"' in v or ' ' in v or '$' in v or '#' in v or '\n' in v or '\t' in v %}
{{ k }}="{{ v | replace('\\', '\\\\') | replace('"', '\\"') }}"
{% else %}
{{ k }}={{ v }}
{% endif %}
{% endfor %}
